MODULARIS_SERVICE_NAME=webhook-service
PORT=8081
MODULARIS_RABBITMQ_URL=amqp://user:user@rabbitmq:5672/
MODULARIS_POSTGRES_URL=postgres://modularis:modularis@postgres:5432/modularis_webhook?sslmode=disable
MODULARIS_POSTGRES_CONNECTION_TIMEOUT=5s
MODULARIS_WEBHOOK_HEADER=x-payment-signature
MODULARIS_WEBHOOK_SECRET=change-this-webhook-secret-at-least-32-characters
MODULARIS_WEBHOOK_TOLERANCE_MS=300000
MODULARIS_WEBHOOK_ROUTING_KEY=payment.callback.confirmed
MODULARIS_WEBHOOK_PUBLISH_ATTEMPTS=3
MODULARIS_WEBHOOK_PUBLISH_DELAY=200ms
MODULARIS_WEBHOOK_PUBLISH_BACKOFF=2
MODULARIS_WEBHOOK_RELAY_BATCH_SIZE=50
MODULARIS_WEBHOOK_RELAY_LEASE=30s
MODULARIS_WEBHOOK_RELAY_TICK=500ms
MODULARIS_WEBHOOK_MAX_BODY_BYTES=1048576
