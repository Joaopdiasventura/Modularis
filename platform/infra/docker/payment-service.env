MODULARIS_SERVICE_NAME=payment-service
PORT=8080
MODULARIS_RABBITMQ_URL=amqp://user:user@rabbitmq:5672/
MODULARIS_MONGO_URI=mongodb://mongo:27017
MODULARIS_MONGO_DATABASE=modularis_payments
MODULARIS_ALLOWED_CURRENCIES=BRL,USD
MODULARIS_WEBHOOK_TOLERANCE_MS=300000
MODULARIS_PAYMENT_EXPIRATION=15m
MODULARIS_PAYMENT_PROCESSING_ATTEMPTS=3
MODULARIS_PAYMENT_PROCESSING_DELAY=100ms
MODULARIS_PAYMENT_PROCESSING_BACKOFF=2
MODULARIS_PAYMENT_SIMULATION_DELAY=200ms
MODULARIS_PAYMENT_SIMULATION_FAILURES_BEFORE_SUCCESS=0
MODULARIS_PAYMENT_SIMULATION_SUCCESS_RATE=1.0
MODULARIS_PAYMENT_SIMULATION_SEED=modularis
MODULARIS_PAYMENT_SIMULATE_WEBHOOK_CONFIRMATION=false
MODULARIS_MONGO_CONNECT_TIMEOUT=5s
