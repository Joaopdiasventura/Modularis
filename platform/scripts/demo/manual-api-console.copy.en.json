      "title": "Payments ready",
      "description": "Checks payment-service readiness through the local proxy.",
      "scenarios": [{ "id": "payment-ready", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "onboarding-live": {
      "id": "onboarding-live",
      "endpointId": "onboarding-live",
      "domain": "onboarding",
      "formType": "health",
      "method": "GET",
      "path": "/internal/onboarding/health/live",
      "visibility": "internal-proxy",
      "title": "Onboarding live",
      "description": "Checks onboarding-service liveness through the local proxy.",
      "scenarios": [{ "id": "onboarding-live", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "onboarding-ready": {
      "id": "onboarding-ready",
      "endpointId": "onboarding-ready",
      "domain": "onboarding",
      "formType": "health",
      "method": "GET",
      "path": "/internal/onboarding/health/ready",
      "visibility": "internal-proxy",
      "title": "Onboarding ready",
      "description": "Checks onboarding-service readiness through the local proxy.",
      "scenarios": [{ "id": "onboarding-ready", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "identity-live": {
      "id": "identity-live",
      "endpointId": "identity-live",
      "domain": "identity",
      "formType": "health",
      "method": "GET",
      "path": "/internal/identity/actuator/health/liveness",
      "visibility": "internal-proxy",
      "title": "Identity live",
      "description": "Checks identity-service liveness through the local proxy.",
      "scenarios": [{ "id": "identity-live", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "identity-ready": {
      "id": "identity-ready",
      "endpointId": "identity-ready",
      "domain": "identity",
      "formType": "health",
      "method": "GET",
      "path": "/internal/identity/actuator/health/readiness",
      "visibility": "internal-proxy",
      "title": "Identity ready",
      "description": "Checks identity-service readiness through the local proxy.",
      "scenarios": [{ "id": "identity-ready", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "membership-live": {
      "id": "membership-live",
      "endpointId": "membership-live",
      "domain": "membership",
      "formType": "health",
      "method": "GET",
      "path": "/internal/membership/actuator/health/liveness",
      "visibility": "internal-proxy",
      "title": "Membership live",
      "description": "Checks membership-service liveness through the local proxy.",
      "scenarios": [{ "id": "membership-live", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "membership-ready": {
      "id": "membership-ready",
      "endpointId": "membership-ready",
      "domain": "membership",
      "formType": "health",
      "method": "GET",
      "path": "/internal/membership/actuator/health/readiness",
      "visibility": "internal-proxy",
      "title": "Membership ready",
      "description": "Checks membership-service readiness through the local proxy.",
      "scenarios": [{ "id": "membership-ready", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "custom": {
      "id": "custom",
      "endpointId": "custom-request",
      "domain": "utility",
      "formType": "custom",
      "method": "ANY",
      "path": "custom",
      "visibility": "utility",
      "title": "Custom request",
      "description": "Sends any manual request outside the main flows.",
      "scenarios": [{ "id": "custom-request", "action": "custom-request", "tone": "secondary", "label": "Send request" }]
    }
  }
}
