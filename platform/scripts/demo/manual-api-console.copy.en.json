{
  "localeCode": "en",
  "fileName": "manual-api-tests.html",
  "publicRoute": "/api/docs",
  "title": "Modularis Flow Demo",
  "routes": {
    "accounts": {
      "id": "accounts",
      "endpointId": "accounts-create",
      "domain": "gateway",
      "formType": "account",
      "method": "POST",
      "path": "/api/accounts",
      "visibility": "public",
      "title": "Create account",
      "description": "Starts onboarding, signs the auth cookie, and returns the first payment intent.",
      "scenarios": [
        { "id": "account-create", "action": "account-create", "tone": "primary", "label": "Create account" },
        { "id": "account-replay", "action": "account-replay", "tone": "secondary", "label": "Replay" },
        { "id": "account-conflict-prime", "action": "account-conflict-prime", "tone": "secondary", "label": "Prime key" },
        { "id": "account-conflict-replay", "action": "account-conflict-replay", "tone": "danger", "label": "Replay conflict" },
        { "id": "account-missing-key", "action": "account-missing-key", "tone": "warning", "label": "Missing key" },
        { "id": "account-invalid-payload", "action": "account-invalid-payload", "tone": "warning", "label": "Invalid payload" },
        { "id": "account-unsupported-currency", "action": "account-unsupported-currency", "tone": "warning", "label": "Unsupported currency" }
      ]
    },
    "events": {
      "id": "events",
      "endpointId": "events-stream",
      "domain": "gateway",
      "formType": "events",
      "method": "GET",
      "path": "/api/events",
      "visibility": "public-protected",
      "title": "Open stream",
      "description": "Keeps the authenticated event stream open for payment and premium updates.",
      "scenarios": [
        { "id": "events-probe", "action": "events-probe", "tone": "warning", "label": "Without auth" },
        { "id": "events-connect", "action": "events-connect", "tone": "primary", "label": "Connect" }
      ]
    },
    "webhook": {
      "id": "webhook",
      "endpointId": "webhook-ingress",
      "domain": "webhook",
      "formType": "webhook",
      "method": "POST",
      "path": "/webhooks/payments",
      "visibility": "public",
      "title": "Confirm webhook",
      "description": "Posts the signed payment confirmation callback.",
      "scenarios": [
        { "id": "webhook-confirmed", "action": "webhook-confirmed", "tone": "primary", "label": "Confirmed" },
        { "id": "webhook-unsupported", "action": "webhook-unsupported", "tone": "warning", "label": "Unsupported status" },
        { "id": "webhook-invalid-signature", "action": "webhook-invalid-signature", "tone": "warning", "label": "Invalid signature" },
        { "id": "webhook-expired-signature", "action": "webhook-expired-signature", "tone": "warning", "label": "Expired signature" }
      ]
    },
    "gateway-live": {
      "id": "gateway-live",
      "endpointId": "gateway-live",
      "domain": "gateway",
      "formType": "health",
      "method": "GET",
      "path": "/api/health/live",
      "visibility": "public",
      "title": "Gateway live",
      "description": "Checks gateway liveness.",
      "scenarios": [{ "id": "gateway-live", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "gateway-ready": {
      "id": "gateway-ready",
      "endpointId": "gateway-ready",
      "domain": "gateway",
      "formType": "health",
      "method": "GET",
      "path": "/api/health/ready",
      "visibility": "public",
      "title": "Gateway ready",
      "description": "Checks gateway readiness and RabbitMQ connectivity.",
      "scenarios": [{ "id": "gateway-ready", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "webhook-live": {
      "id": "webhook-live",
      "endpointId": "webhook-live",
      "domain": "webhook",
      "formType": "health",
      "method": "GET",
      "path": "/webhooks/health/live",
      "visibility": "public",
      "title": "Webhook live",
      "description": "Checks webhook ingress liveness.",
      "scenarios": [{ "id": "webhook-live", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "webhook-ready": {
      "id": "webhook-ready",
      "endpointId": "webhook-ready",
      "domain": "webhook",
      "formType": "health",
      "method": "GET",
      "path": "/webhooks/health/ready",
      "visibility": "public",
      "title": "Webhook ready",
      "description": "Checks webhook publishing readiness.",
      "scenarios": [{ "id": "webhook-ready", "action": "health-run", "tone": "secondary", "label": "Run" }]
    },
    "payment-live": {
      "id": "payment-live",
      "endpointId": "payment-live",
      "domain": "payments",
      "formType": "health",
      "method": "GET",
      "path": "/internal/payment/health/live",
      "visibility": "internal-proxy",
      "title": "Payments live",
      "description": "Checks payment-service liveness through the local proxy.",
      "scenarios": [{ "id": "payment-live", "action": "health-run", "tone": "secondary", "label": "Run" }]
