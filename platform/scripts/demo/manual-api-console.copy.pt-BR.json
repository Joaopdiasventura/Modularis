        { "id": "account-conflict-replay", "action": "account-conflict-replay", "tone": "danger", "label": "Repetir com conflito" },
        { "id": "account-missing-key", "action": "account-missing-key", "tone": "warning", "label": "Sem chave" },
        { "id": "account-invalid-payload", "action": "account-invalid-payload", "tone": "warning", "label": "Payload inválido" },
        { "id": "account-unsupported-currency", "action": "account-unsupported-currency", "tone": "warning", "label": "Moeda não suportada" }
      ]
    },
