NODE_ENV=production
PORT=3000
MODULARIS_SERVICE_NAME=api-gateway
MODULARIS_ALLOWED_ORIGINS=http://localhost
MODULARIS_RABBITMQ_URL=amqp://user:user@rabbitmq:5672/
MODULARIS_COMMAND_EXCHANGE=modularis.commands
MODULARIS_EVENT_EXCHANGE=modularis.events
MODULARIS_RESPONSE_EXCHANGE=modularis.responses
MODULARIS_RPC_TIMEOUT_MS=5000
MODULARIS_JWT_SECRET=change-this-for-production-at-least-32-characters
MODULARIS_JWT_EXPIRES_IN=1h
MODULARIS_AUTH_COOKIE_NAME=modularis_auth
MODULARIS_AUTH_COOKIE_SECURE=false
MODULARIS_AUTH_COOKIE_SAMESITE=lax
MODULARIS_GATEWAY_RATE_LIMIT_TTL_MS=60000
MODULARIS_GATEWAY_RATE_LIMIT_LIMIT=30
