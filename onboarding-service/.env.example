NODE_ENV=production
PORT=3000
MODULARIS_SERVICE_NAME=onboarding-service
MODULARIS_RABBITMQ_URL=amqp://user:user@rabbitmq:5672/
MODULARIS_COMMAND_EXCHANGE=modularis.commands
MODULARIS_EVENT_EXCHANGE=modularis.events
MODULARIS_RESPONSE_EXCHANGE=modularis.responses
MODULARIS_RPC_TIMEOUT_MS=5000
MODULARIS_POSTGRES_URL=postgresql://modularis:modularis@postgres:5432/modularis_onboarding
MODULARIS_POSTGRES_CONNECTION_TIMEOUT_MS=5000
MODULARIS_ONBOARDING_COMMAND_QUEUE=onboarding-service.command.account-create
